# ─── Root .gitignore for Mytube monorepo ───

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment secrets (never commit real credentials)
.env
.env.local
.env.*.local

# Node
node_modules/

# Build output
dist/
.next/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Render / Netlify local cache
.netlify/
