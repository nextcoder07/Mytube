# Frontend Environment Variables — EXAMPLE
# Copy this to `.env.local` and fill in real values.
# .env.local is git-ignored; .env.example is safe to commit.
# In production, set these in the Netlify UI.

# Base URL for the Express Backend API
# → Local dev: http://localhost:4000/api
# → Production: https://mytube-backend.onrender.com/api (your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Firebase Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:xxx:web:xxx
